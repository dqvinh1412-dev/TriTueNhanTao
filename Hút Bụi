# SIMPLE REFLEX AGENT - MÁY HÚT BỤI

import random

# PEAS
# Performance: Làm sạch môi trường
# Environment: Ma trận m x n (0 = sạch, 1 = bẩn)
# Actuators: UP, DOWN, LEFT, RIGHT, VACUUM
# Sensors: Đọc vị trí hiện tại, Đọc trạng thái ô hiện tại

# MÔI TRƯỜNG

room = [
    [1, 0, 1],
    [0, 1, 0],
    [1, 0, 1]
]

m = len(room)
n = len(room[0])

# vị trí ban đầu của agent
x = 0
y = 0

# IN MA TRẬN

def print_room():
    for row in room:
        print(row)
    print()

# RULES
# possible_move(x,y)

def possible_move(x, y):
    move = []
    if x > 0:
        move.append("UP")
    if x < m - 1:
        move.append("DOWN")
    if y > 0:
        move.append("LEFT")
    if y < n - 1:
        move.append("RIGHT")
    return move

# DI CHUYỂN AGENT

def move_agent(action, x, y):
    if action == "UP":
        x -= 1
    elif action == "DOWN":
        x += 1
    elif action == "LEFT":
        y -= 1
    elif action == "RIGHT":
        y += 1
    return x, y


# KIỂM TRA CÒN BỤI KHÔNG

def still_dirty():
    for row in room:
        if 1 in row:
            return True
    return False

# CHẠY THUẬT TOÁN

step = 1

print("TRẠNG THÁI BAN ĐẦU")
print_room()

while still_dirty():
    print("STEP =", step)
    print("Agent position =", (x, y))

    state_value = room[x][y]

    # If state_value = 0 then action = random(move)
    if state_value == 0:
        print("Trạng thái: SẠCH")

        moves = possible_move(x, y)
        print("Possible move =", moves)

        action = random.choice(moves)
        print("Action = Di chuyển", action)

        x, y = move_agent(action, x, y)

    # If state_value = 1 then state_value = 0 and action = random(move)
    elif state_value == 1:
        print("Trạng thái: BẨN")
        print("Action 1 = VACUUM (Hút bụi)")
        room[x][y] = 0  # state_value = 0

        # Di chuyển ngay trong cùng 1 step (and action = random(move))
        moves = possible_move(x, y)
        print("Possible move =", moves)

        action = random.choice(moves)
        print("Action 2 = Di chuyển", action)

        x, y = move_agent(action, x, y)

    print("\nMÔI TRƯỜNG HIỆN TẠI")
    print_room()
    print("-------------------------")

    step += 1

print("HOÀN THÀNH")
print(f"TẤT CẢ Ô ĐÃ ĐƯỢC LÀM SẠCH SAU {step - 1} BƯỚC!")
